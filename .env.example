# Telegram user API (https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# Group to read messages from (@username or numeric id, e.g. -1001234567890)
TELEGRAM_GROUP=

# Telegram bot that posts summary to a channel
TELEGRAM_BOT_TOKEN=
# Channel id or @username (bot must be admin with post permission)
TELEGRAM_CHANNEL=

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Optional: free model id from https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Fallback when the primary model is rate-limited (openrouter/free picks any free model)
OPENROUTER_FALLBACK_MODEL=openrouter/free

# Calendar day boundaries for "last 24 hours" summary
TIMEZONE=Europe/Minsk
