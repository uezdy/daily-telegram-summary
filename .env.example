# Telegram user API (https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=

# Telegram bot that posts summary to a channel
TELEGRAM_BOT_TOKEN=
# Channel id or @username (bot must be admin with post permission)
TELEGRAM_CHANNEL=

# Yandex Cloud Foundation Models (https://yandex.cloud/docs/foundation-models/)
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER_ID=
# Optional model id: yandexgpt-lite (default), yandexgpt, yandexgpt/latest
YANDEXGPT_MODEL=

# Calendar day boundaries for the summary period
TIMEZONE=Europe/Minsk
# How many previous calendar days to include (default: 2)
SUMMARY_PERIOD_DAYS=2
